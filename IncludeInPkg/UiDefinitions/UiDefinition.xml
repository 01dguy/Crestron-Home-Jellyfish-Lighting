<?xml version="1.0" encoding="utf-8" ?>
<uidefinition xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:noNamespaceSchemaLocation="https://prd-use-rad-assets.azurewebsites.net/ExtensionsSchemaDefinition.xsd">
  <version ver="1.0"/>
  <tile icon="#icSun" navigation="show:MainPage" showinhomepage="#true" showinroompage="#false"/>
  <layouts>
    <layout id="MainPage" title="^MainPageTitle" isdefaultlayout="#true">
      <controls>
        <textdisplay id="StatusTextId" title="^StatusTextLabel" line1label="{StatusText}" line2label="{ZoneSummary}"/>
        <textdisplay id="OnlineTextId" title="^OnlineLabel" line1label="{ActiveScene}" line2label="{Brightness}"/>
        <textdisplay id="SpeedTextId" title="^SpeedLabel" line1label="{Speed}"/>
        <subheader id="ControlsSubheader" label="^CommonActionsSubheaderLabel"/>
        <controlgroup>
          <textentry id="PatternPathId" label="^PatternPathLabel" value="{PatternPath}"/>
          <textentry id="SelectedZonesId" label="^SelectedZonesLabel" value="{SelectedZones}"/>
          <textentry id="RequestedBrightnessId" label="^RequestedBrightnessLabel" value="{RequestedBrightness}" numericinputonly="#true"/>
          <textentry id="RequestedSpeedId" label="^RequestedSpeedLabel" value="{RequestedSpeed}" numericinputonly="#true"/>
        </controlgroup>
        <button id="RefreshButtonId" label="^RefreshNowLabel" action="command:RefreshNow"/>
        <button id="GetPatternsButtonId" label="^GetPatternsAndZonesLabel" action="command:GetPatternsAndZones"/>
        <button id="RequestPatternDataButtonId" label="^RequestPatternDataLabel" action="command:RequestPatternData"/>
        <button id="RunPatternButtonId" label="^RunSelectedPatternLabel" action="command:RunSelectedPattern"/>
        <button id="SetBrightnessButtonId" label="^SetSelectedBrightnessLabel" action="command:SetSelectedBrightness"/>
        <button id="SetSpeedButtonId" label="^SetSelectedSpeedLabel" action="command:SetSelectedSpeed"/>
        <button id="PowerOnButtonId" label="^PowerOnLabel" action="command:PowerOn"/>
        <button id="PowerOffButtonId" label="^PowerOffLabel" action="command:PowerOff"/>
        <button id="SettingsButtonId" label="^ButtonSettingsLabel" navigation="show:SettingsPage" action="command:ShowSettings"/>
      </controls>
    </layout>
    <layout id="SettingsPage" title="^SettingsPageTitle">
      <controls>
        <subheader id="PollingSubheader" label="^PollingSubheaderLabel"/>
        <controlgroup>
          <checkbox id="UseSslId" label="^UseSslLabel" secondarylabel="^UseSslSecondaryLabel" value="{UseSsl}"/>
          <textentry id="HostId" label="^HostLabel" value="{ControllerHost}"/>
          <textentry id="PollIntervalId" label="^PollIntervalLabel" value="{PollIntervalSeconds}" numericinputonly="#true"/>
        </controlgroup>
        <button id="SaveButtonId" label="^SaveButtonName" action="command:SaveSettings"/>
      </controls>
    </layout>
  </layouts>
  <alerts/>
</uidefinition>
