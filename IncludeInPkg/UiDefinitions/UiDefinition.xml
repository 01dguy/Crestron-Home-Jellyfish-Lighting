<?xml version="1.0" encoding="utf-8" ?>
<uidefinition xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:noNamespaceSchemaLocation="https://prd-use-rad-assets.azurewebsites.net/ExtensionsSchemaDefinition.xsd">
  <version ver="1.0"/>

  <!-- Tile: tap to toggle power, ellipsis for navigation -->
  <tile icon="#icHeatingRegular"
        status="{StatusText}"
        navigation="show:MainPage"
        showinhomepage="#true"
        showinroompage="#true"/>

  <layouts>
    <!-- Main page -->
    <layout id="MainPage" title="^MainPageTitle" isdefaultlayout="#true">
      <controls>
        <textdisplay id="StatusTextId"
                     title="^StatusTextLabel"
                     line1label="{StatusText}"
                     line2label="{ZoneSummary}"/>

        <textdisplay id="SceneTextId"
                     title="^SceneLabel"
                     line1label="{ActiveScene}"/>

        <subheader id="PowerSubheader" label="^PowerSubheaderLabel"/>

        <toggle id="PowerToggleId"
                label="^PowerToggleLabel"
                secondarylabel="{StatusText}"
                value="{PowerState}"/>

        <subheader id="ScenesSubheader" label="^ScenesSubheaderLabel"/>

        <!-- Parent scenes listbutton -->
        <listbutton id="ParentScenesListButtonId"
            label="^ParentScenesLabel"
            source="{ParentScenes}"
            itemlabel="{.name}"
            action="command:SelectParentScene"
            actionparameters="{.id},{.name}"
            navigation="show:ChildScenesPage"
            navigationparameters="{.id},{.name}"
            visible="{HasParentScenes}"
            enabled="{HasParentScenes}"/>

        <button id="RefreshButtonId" 
                label="^RefreshNowLabel" 
                action="command:RefreshNow"
                visible="#false"/>
        
        <button id="GetPatternsButtonId" 
                label="^GetPatternsAndZonesLabel"
                icon="icRepeat"
                action="command:GetPatternsAndZones"/>

        <button id="SettingsButtonId"
                label="^ButtonSettingsLabel"
                icon="icFineTuneRegular"
                navigation="show:SettingsPage"
                action="command:ShowSettings"/>
      </controls>
    </layout>

    <!-- Child scenes page -->
    <layout id="ChildScenesPage"
            title="^ChildScenesPageTitle"
            subtitle="{$ParentSceneName}"
            inputparameters="$ParentSceneId,$ParentSceneName">
      <controls>
        <textdisplay id="SelectedParentTextId"
                     title="^SelectedParentLabel"
                     line1label="{$ParentSceneName}"
                     line2label="{ActiveScene}"/>

        <listbutton id="ChildScenesListButtonId"
                    label="^ChildScenesLabel"
                    source="{ChildScenes}"
                    itemlabel="{.name}"
                    action="command:RunChildScene"
                    actionparameters="{.id},{.name}"/>

        <toggle id="ChildPagePowerToggleId"
                label="^PowerToggleLabel"
                secondarylabel="{StatusText}"
                value="{PowerState}"
                visible="#false"/>

        <button id="BackToMainButtonId"
                label="^BackToMainLabel"
                navigation="show:MainPage"
                visible="#false"/>
      </controls>
    </layout>

    <!-- Settings page -->
    <layout id="SettingsPage" title="^SettingsPageTitle">
      <controls>
        <subheader id="PollingSubheader" label="^PollingSubheaderLabel"/>
        <textdisplay id="HostId" title="^HostLabel" line1label="{ControllerHostDisplay}"/>
        <textentry id="PollIntervalId" label="^PollIntervalLabel" value="{PollIntervalSeconds}" numericinputonly="#true"/>
        <button id="SaveButtonId" label="^SaveButtonName" action="command:SaveSettings"/>
      </controls>
    </layout>
  </layouts>

  <alerts/>
</uidefinition>
